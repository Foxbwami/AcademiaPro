# Environment Variables for AcademiaPro

# Flask Configuration
SECRET_KEY=your_secret_key_here_change_in_production
FLASK_ENV=production

# Database
SQLALCHEMY_DATABASE_URI=sqlite:///your.db

# Email Configuration (Resend)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@academipro.com
EMAIL_OTP_ENABLED=true

# Admin Configuration
ADMIN_EMAILS=admin@example.com,admin2@example.com
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=secure_password_change_me
AUTO_ASSIGN_ADMIN_EMAILS=false
ADMIN_ONLY_MODE=false

# Groq AI Configuration
GROQ_API_KEY=gsk-your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT=90
GROQ_MAX_TOKENS=6000
# Server Configuration
HOST=0.0.0.0
PORT=8000
