# Environment Variables for AcademiaPro

# Flask Configuration
SECRET_KEY=your_secret_key_here_change_in_production
FLASK_ENV=production

# Database
SQLALCHEMY_DATABASE_URI=sqlite:///your.db

# Email Configuration (Resend)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@academipro.com
EMAIL_OTP_ENABLED=true

# Admin Configuration
ADMIN_EMAILS=admin@example.com,admin2@example.com
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=secure_password_change_me
AUTO_ASSIGN_ADMIN_EMAILS=false

# Grok AI Configuration
GROK_API_KEY=gsk_your_actual_api_key_here

# Server Configuration
HOST=0.0.0.0
PORT=8000
